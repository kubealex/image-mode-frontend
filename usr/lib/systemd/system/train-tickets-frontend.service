[Unit]
Description=Train Tickets Frontend (Vite Dev Server)
After=systemd-tmpfiles-setup.service

[Service]
Type=simple
WorkingDirectory=/var/app/frontend
ExecStart=/usr/bin/npx vite --host
Restart=on-failure
RestartSec=5

EnvironmentFile=-/etc/train-tickets/frontend.env

[Install]
WantedBy=multi-user.target
